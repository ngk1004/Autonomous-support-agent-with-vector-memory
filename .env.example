# PostgreSQL
POSTGRES_USER=support_agent
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=support_agent

# n8n secrets (generate with: openssl rand -hex 16 / openssl rand -hex 32)
N8N_ENCRYPTION_KEY=ed91f5d83898733947f0898c6f6f57a4
N8N_USER_MANAGEMENT_JWT_SECRET=30b73bb63ee927d8ec3bf5b6433df5239474fc4d1863d2f609d0107dc2d4f14d

# Ollama (use host.docker.internal:11434 if running Ollama natively on Mac)
OLLAMA_HOST=ollama:11434

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Optional webhook security
WEBHOOK_AUTH_TOKEN=demo_webhook_token_change_me

# Intent routing — below this confidence, inquiry is escalated to human
INTENT_CONFIDENCE_THRESHOLD=0.55

# Gmail (OAuth configured in n8n UI — this is for workflow reference)
GMAIL_FROM_ADDRESS=you@gmail.com

# n8n timezone
GENERIC_TIMEZONE=America/New_York
